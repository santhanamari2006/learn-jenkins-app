{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "LearnJenkinsApp-TaskDefinition-Prod",
    "containerDefinitions": [
        {
            "name": "learnjenkinsapp",
            "image": "nginx:1.27-alpine",
            "portMappings": [{
                "name": "071604987339.dkr.ecr.ap-south-1.amazonaws.com/learnjenkinsappname:#APP_VERSION#",
                "containerPort": 80,
                "hostPort": 80,
                "protocol": "tcp",
                "appProtocol": "http"
            }],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::071604987339:role/ecsTaskExecutionRole"
}